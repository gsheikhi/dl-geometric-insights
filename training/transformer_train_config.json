    "en_rope_pe_path":    "data/embeddings/en_rope_pe.npz",
    "tr_rope_pe_path":    "data/embeddings/tr_rope_pe.npz",
    "en_tokenised_path":  "data/en_tokenised.json",
    "tr_tokenised_path":  "data/tr_tokenised.json",
    "en_vocab_path":      "data/en_vocab.json",
    "tr_vocab_path":      "data/tr_vocab.json"
